{
  "name": "@blazyts/backend-lib",
  "type": "module",
  "version": "1.0.0",
  "module": "index.ts",
  "scripts": {
    "lint": "bun --bun eslint src tests",
    "build": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun x vitest run --config vitest.config.ts", // uses bun to execute the vitest test runner which uses node as a runner 
    "coverage": "bun test --coverage",
    "bun:test": "bun test" // uses bun as a runtime, uses it test runner and run the test
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@blazyts/better-standard-library": "workspace:*",
    "@blazyts/http-types": "workspace:*",
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "bun-types": "latest",
    "eslint": "^9.39.2"
  }
}
